{% comment %}
  SiGNL Bundle Builder — Page Section Block
  Renders the bundle builder on any page (homepage, landing pages, etc.)
  The bundle to display is selected by Bundle ID in the block settings.
{% endcomment %}

{{ 'bundle-picker.css' | asset_url | stylesheet_tag }}

{% if block.settings.show_heading and block.settings.heading != blank %}
  <h2 class="signl-bundle-picker__section-heading">{{ block.settings.heading }}</h2>
{% endif %}

{% assign bundle_id = block.settings.bundle_id | strip %}

{% if bundle_id != blank %}
  <div
    class="signl-bundle-picker"
    data-shop="{{ shop.permanent_domain }}"
    data-bundle-id="{{ bundle_id }}"
    data-app-url="{{ block.settings.app_url }}"
    data-currency="{{ cart.currency.iso_code }}"
    aria-live="polite"
  >
    <div class="signl-bp__loading">
      <div class="signl-bp__spinner"></div>
      <p>Loading bundle&hellip;</p>
    </div>
  </div>
{% else %}
  <p style="color:#6b7280;font-size:0.875rem;text-align:center;padding:1rem 0;">
    Please enter a Bundle ID in the theme editor settings to display a bundle here.
  </p>
{% endif %}

<script src="{{ 'bundle-picker.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "SiGNL Bundle Builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "info": "Your SiGNL Bundle Builder app URL, e.g. https://your-app.replit.app",
      "placeholder": "https://your-app.replit.app"
    },
    {
      "type": "text",
      "id": "bundle_id",
      "label": "Bundle ID",
      "info": "Enter the numeric ID of the bundle to display on this page. Find it in the SiGNL Bundle Builder app.",
      "placeholder": "42"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show section heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Build Your Bundle"
    }
  ],
  "presets": [
    {
      "name": "SiGNL Bundle Builder"
    }
  ]
}
{% endschema %}
